{
  "점열_대칭이동": {
    "description": "교재 이미지: y=x 대칭 + y=(1/3)x 교점으로 점 A_n 생성",
    "xRange": [-1, 10],
    "yRange": [-1, 6],
    "functions": [
      {"fn": "x", "label": "y=x"},
      {"fn": "(1/3)*x", "label": "y=⅓x"}
    ],
    "points": [
      {"x": 2, "y": 4, "label": "A_1"},
      {"x": 4, "y": 2, "label": "A_2"},
      {"x": 4, "y": 1.333, "label": "A_3"},
      {"x": 1.333, "y": 4, "label": "A_4"},
      {"x": 8, "y": 1.333, "label": "A_5"}
    ],
    "segments": [
      {"x1": 2, "y1": 4, "x2": 4, "y2": 2, "dashed": true},
      {"x1": 4, "y1": 2, "x2": 4, "y2": 1.333, "dashed": true},
      {"x1": 4, "y1": 1.333, "x2": 8, "y2": 1.333, "dashed": true}
    ]
  },

  "단위원_삼각함수": {
