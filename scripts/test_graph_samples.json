  "이차함수_적분영역": {
    "description": "y=x²과 y=2x 사이 영역 + 교점 표시",
    "xRange": [-1, 3],
    "yRange": [-1, 5],
    "functions": [
      {"fn": "x^2", "label": "y=x²"},
      {"fn": "2*x", "label": "y=2x"}
    ],
    "points": [
      {"x": 0, "y": 0, "label": "O"},
      {"x": 2, "y": 4, "label": "A"}
    ],
    "regions": [
      {"fn": "2*x - x^2", "x1": 0, "x2": 2}
    ],
    "texts": [
      {"x": 0.8, "y": 0.8, "text": "S"}
    ]
  },

  "삼각함수_그래프": {
    "description": "y=sin(x)와 y=cos(x) 두 곡선, 교점 표시",
