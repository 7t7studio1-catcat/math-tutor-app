    "yRange": [-1, 6],
    "noAxes": true,
    "segments": [
      {"x1": 0, "y1": 0, "x2": 6, "y2": 0, "solid": true, "label": "c"},
      {"x1": 0, "y1": 0, "x2": 2, "y2": 5, "solid": true, "label": "b"},
      {"x1": 6, "y1": 0, "x2": 2, "y2": 5, "solid": true, "label": "a"},
      {"x1": 2, "y1": 5, "x2": 2, "y2": 0, "dashed": true, "label": "h"}
